{
  "name": "hcb-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "EXPO_PUBLIC_APP_VARIANT=development expo run:android",
    "ios": "EXPO_PUBLIC_APP_VARIANT=development expo run:ios",
    "lint": "eslint ./app/ ./components/ ./lib/ ./styles/ ./utils/",
    "lint:fix": "eslint ./app/ ./components/ ./lib/ ./styles/ ./utils/ --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "ts:check": "tsc",
    "postinstall": "patch-package && node scripts/bundle-yellowpages.js",
    "bundle:yellowpages": "node scripts/bundle-yellowpages.js",
    "eas-build-pre-install": "./.eas/hooks/pre-build.sh",
    "eas-build-post-install": "./.eas/hooks/post-install.sh",
    "publish:update": "node scripts/publish-update.js"
  },
  "dependencies": {
    "@expo/image-utils": "^0.6.3",
    "@expo/ngrok": "^4.1.3",
    "@expo/react-native-action-sheet": "^4.1.0",
    "@expo/ui": "~56.0.12",
    "@expo/vector-icons": "^15.0.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/react-native-fontawesome": "^0.3.2",
    "@intercom/intercom-react-native": "^9.5.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/geolocation": "^3.3.0",
    "@react-native-community/netinfo": "12.0.1",
    "@sentry/cli": "^2.44.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@stripe/stripe-react-native": "0.64.0",
    "@stripe/stripe-terminal-react-native": "^0.0.1-beta.26",
    "@thedev132/hackclub-icons-rn": "^0.0.18",
    "buffer": "^6.0.3",
    "date-fns": "^2.30.0",
    "expo": "~56.0.3",
    "expo-alternate-app-icons": "^1.4.0",
    "expo-auth-session": "~56.0.11",
    "expo-background-task": "~56.0.13",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.13",
    "expo-checkbox": "~56.0.1",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.14",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.8",
    "expo-image-manipulator": "~56.0.13",
    "expo-image-picker": "~56.0.12",
    "expo-insights": "~56.0.12",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-local-authentication": "~56.0.4",
    "expo-location": "~56.0.12",
    "expo-notifications": "~56.0.12",
    "expo-router": "~56.2.5",
    "expo-screen-capture": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-share-intent": "^6.1.0",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "~56.0.3",
    "expo-system-ui": "~56.0.5",
