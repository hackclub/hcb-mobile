    "expo-web-browser": "~56.0.5",
    "hcb-geo-pattern": "^1.1.0",
    "humanize-string": "^3.0.0",
    "ky": "^1.2.3",
    "lodash": "^4.17.21",
    "patch-package": "^8.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-alert-notification": "^0.4.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-image-viewing": "^0.2.2",
    "react-native-progress": "^5.0.1",
    "react-native-qrcode-styled": "^0.3.3",
    "react-native-reanimated": "4.3.1",
    "react-native-reorderable-list": "^0.16.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-svg": "15.15.4",
    "react-native-watch-connectivity": "^1.1.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "swr": "^2.3.6",
    "to-words": "^4.2.0",
    "ts-pattern": "^5.0.8",
    "use-debounce": "^10.0.4"
  },
  "devDependencies": {
    "@tsconfig/react-native": "^3.0.2",
    "@types/jest": "^29.5.5",
    "@types/lodash": "^4.14.198",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^18.0.3",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "eas-build-cache-provider": "^16.4.2",
    "eslint": "^8.49.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.0.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "overrides": {
    "@stripe/stripe-terminal-react-native": {
      "react": "$react",
      "react-native": "$react-native"
    },
    "expo-share-intent": {
      "expo-constants": "$expo-constants",
      "expo-linking": "$expo-linking"
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@stripe/stripe-terminal-react-native"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
