{
  "compilerOptions": {
    "jsx": "react-jsx",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "extends": "expo/tsconfig.base",
  "include": ["auth/**/*", "lib/**/*", "providers/**/*", "styles/**/*", "utils/**/*", "components/**/*", "app/App.tsx", "env.d.ts", "app"]
}
